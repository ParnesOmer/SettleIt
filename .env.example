# SettleIt — environment reference.
# Copy to backend/.env for the API:  cp .env.example backend/.env
# Never commit a filled-in .env. AI keys are server-side only — never expose them to the client.

# ---- Database ----
# Async SQLAlchemy URL (asyncpg driver). Matches the docker-compose Postgres (host port 5433).
DATABASE_URL=postgresql+asyncpg://settleit:settleit@localhost:5433/settleit

# ---- LLM providers ----
# Primary provider, with automatic fallback to Groq when the primary's quota is exhausted.
# Options: gemini | groq
LLM_PROVIDER=gemini
# Gemini (Google AI Studio free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Groq fallback (free tier). Optional — leave blank to run Gemini solo.
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Web search (grounded mission starter links) ----
# Tavily: https://app.tavily.com  — only Tavily results are ever persisted as mission links.
TAVILY_API_KEY=

# ---- App ----
# Signs anonymous session cookies. Generate one with:  openssl rand -hex 32
SESSION_SECRET=change-me-in-production
# Comma-separated origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:5173
# development | production
ENV=development

# ---- Frontend (Vite) ----
# Optional. The browser uses this to reach the API; defaults to http://localhost:8001.
VITE_API_URL=http://localhost:8001
